    <sys:String x:Key="L.Sum.FailedItem">Selhalo</sys:String>
    <sys:String x:Key="L.Sum.SkippedItem">Přeskočeno</sys:String>

    <!-- CLM Warning Dialog -->
    <sys:String x:Key="L.Diag.Clm.Title">Varování o izolovaném spuštění</sys:String>
    <sys:String x:Key="L.Diag.Clm.Msg">Zapnutí [izolovaného spouštění PowerShellu] uzamkne všechny skripty do režimu omezeného jazyka (CLM).&#x0a;&#x0a;To brání skriptům v používání .NET reflexe, COM objektů a dalších pokročilých funkcí. V důsledku toho:&#x0a;&#x0a;  • Některé složité úpravy (např. [instalace modovaného IDM]) selžou.&#x0a;  • Skripty spoléhající na externí .NET API budou [zablokovány].&#x0a;&#x0a;Aktivujte pouze pokud rozumíte důsledkům. Pokračovat?</sys:String>
    <sys:String x:Key="L.Diag.Clm.Confirm">Aktivovat CLM</sys:String>
    <sys:String x:Key="L.Diag.Clm.Cancel">Zpět</sys:String>

    <!-- Portable Mode Dialogs -->
    <sys:String x:Key="L.Diag.Portable.Enable.Title">Aktivovat přenosný režim</sys:String>
    <sys:String x:Key="L.Diag.Portable.Enable.Msg">**Přenosný režim** uchovává všechna data WinZ striktně v [paměti] – na disk se nezapisují žádné databázové soubory.&#x0a;&#x0a;To znamená:&#x0a;&#x0a;  • Váš výběr úloh a nastavení [NEBUDOU] mezi relacemi uloženy.&#x0a;  • Historie instalací bude při zavření aplikace [ztracena].&#x0a;  • Pro projevení změny je [nutný restart] aplikace.&#x0a;&#x0a;Vedle spustitelného souboru bude umístěn soubor (**winz.portable**) pro aktivaci tohoto režimu při příštím spuštění.&#x0a;&#x0a;Pokračovat?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Title">Deaktivovat přenosný režim</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Msg">Deaktivací přenosného režimu se obnoví trvalé lokální úložiště. Při příštím spuštění bude ve vaší složce AppData vytvořen databázový soubor.&#x0a;&#x0a;Pro projevení změny je nutný restart aplikace. Pokračovat?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Confirm">Restartovat nyní</sys:String>
    <sys:String x:Key="L.Diag.Portable.Cancel">Zpět</sys:String>

    <!-- Error Messages -->
    <sys:String x:Key="L.Err.Cancelled">Uživatel zrušil operaci</sys:String>

