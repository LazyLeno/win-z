    <!-- Task Descriptions -->
    <sys:String x:Key="L.Desc.sw_librewolf">Prohlížeč Firefox zaměřený na soukromí s vylepšeným výchozím zabezpečením.</sys:String>
    <sys:String x:Key="L.Desc.sw_brave">Rychlý prohlížeč s vestavěným blokováním reklam a ochranou soukromí.</sys:String>
    <sys:String x:Key="L.Desc.sw_idm">Vysokorychlostní akcelerátor stahování pro všechny vaše soubory.</sys:String>
    <sys:String x:Key="L.Desc.sw_qbittorrent">Open-source alternativa k µTorrentu s pokročilými funkcemi.</sys:String>
    <sys:String x:Key="L.Desc.sw_protonvpn">Bezpečná VPN bez protokolování od tvůrců ProtonMailu.</sys:String>
    <sys:String x:Key="L.Desc.sw_simplewall">Snadná konfigurace platformy Windows Filtering Platform (WFP).</sys:String>
    <sys:String x:Key="L.Desc.sw_malwarebytes">Pokročilá kybernetická bezpečnost pro domácnosti i firmy.</sys:String>
    <sys:String x:Key="L.Desc.sw_keepassxc">Multiplatformní, komunitou vyvíjený správce hesel.</sys:String>
    <sys:String x:Key="L.Desc.sw_discord">Hlasová, video a textová komunikace pro komunity.</sys:String>
    <sys:String x:Key="L.Desc.sw_obsidian">Výkonná lokální znalostní báze založená na Markdownu.</sys:String>
    <sys:String x:Key="L.Desc.sw_pear_desktop">Desktopový klient YouTube Music s mnoha funkcemi.</sys:String>
    <sys:String x:Key="L.Desc.sw_vlc">Bezplatný multiplatformní multimediální přehrávač pro všechno.</sys:String>
    <sys:String x:Key="L.Desc.sw_blender">Kompletní sada pro 3D tvorbu (zdarma a open source).</sys:String>
    <sys:String x:Key="L.Desc.sw_obs_studio">Profesionální software pro nahrávání a streamování.</sys:String>
    <sys:String x:Key="L.Desc.sw_steam">Špičková platforma pro hraní a diskuse o hrách.</sys:String>
    <sys:String x:Key="L.Desc.sw_epic">Obchod Epic Games a oficiální spouštěč her.</sys:String>
    <sys:String x:Key="L.Desc.sw_vscode">Výkonná úprava kódu, nově definovaná pro každého.</sys:String>
    <sys:String x:Key="L.Desc.sw_notepadplus">Lehký editor zdrojového kódu a náhrada za Poznámkový blok.</sys:String>
    <sys:String x:Key="L.Desc.sw_sharex">Pokročilý nástroj pro snímání obrazovky a sdílení souborů.</sys:String>
    <sys:String x:Key="L.Desc.sw_7zip">Archivátor s vysokým kompresním poměrem a open source kořeny.</sys:String>
    <sys:String x:Key="L.Desc.sw_winrar">Výkonný správce archivů ZIP, RAR a dalších.</sys:String>
    <sys:String x:Key="L.Desc.sw_onecommander">Moderní dvoupanelový správce souborů s pokročilými funkcemi.</sys:String>
    <sys:String x:Key="L.Desc.sw_directory_opus">Profesionální náhrada Průzkumníka Windows.</sys:String>
    <sys:String x:Key="L.Desc.tweak_verbose_login">Zobrazovat podrobné stavové zprávy během přihlašování/vypínání.</sys:String>
    <sys:String x:Key="L.Desc.tweak_disable_cortana">Zakáže integraci vyhledávání Cortana v celém systému.</sys:String>
    <sys:String x:Key="L.Desc.rem_xbox_overlay">Odstraní aplikaci Xbox herní panel.</sys:String>
    <sys:String x:Key="L.Desc.set_allow_modded">Povolí alternativní, komunitou upravené verze určitého softwaru.</sys:String>
    <sys:String x:Key="L.Desc.set_prompt_restore">Dotázat se na vytvoření bodu obnovení před spuštěním jakékoli úlohy.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_cleanup">Vymaže dočasnou složku Windows a mezipaměti správců balíčků po úspěšném spuštění.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_update">Automaticky aktualizuje repozitáře Winget a Scoop při spuštění aplikace.</sys:String>
    <sys:String x:Key="L.Desc.set_verify_checksums">Vypočítá a ověří hashe SHA-256 u všech instalátorů z přímého stahování, aby detekoval manipulaci před spuštěním.</sys:String>
    <sys:String x:Key="L.Desc.set_clm_mode">Spustí všechny skripty úprav v režimu PowerShell Constrained Language Mode. Zvyšuje zabezpečení, ale může narušit skripty používající typy .NET nebo objekty COM.</sys:String>
    <sys:String x:Key="L.Desc.set_portable_mode">Uchovává všechna data v paměti RAM – na disk se nezapisují žádné databázové soubory. Ideální pro použití na USB. Vyžaduje restart; všechna data relace budou při ukončení ztracena.</sys:String>

