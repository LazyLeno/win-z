    <!-- Dialogs -->
    <sys:String x:Key="L.Diag.Ready.Title">Připraveno k aplikaci změn</sys:String>
    <sys:String x:Key="L.Diag.Ready.Msg">Vybraný software a úpravy budou nyní aplikovány na váš systém.&#x0a;&#x0a;Ujistěte se, že máte uloženou práci, protože některé operace mohou restartovat systémové komponenty.</sys:String>
    <sys:String x:Key="L.Diag.Ready.Confirm">Spustit nastavení</sys:String>
    
    <sys:String x:Key="L.Diag.Safety.Title">Ochrana systému</sys:String>
    <sys:String x:Key="L.Diag.Safety.Msg">Před aplikací těchto změn se důrazně doporučuje vytvořit bod obnovení systému. To vám zajistí záchrannou síť, pokud by se cokoli chovalo neočekávaně.&#x0a;&#x0a;Chcete nyní vytvořit bod obnovení? (Trvá to ~30 sekund)</sys:String>
    <sys:String x:Key="L.Diag.Safety.Confirm">Vytvořit bod</sys:String>
    <sys:String x:Key="L.Diag.Safety.Skip">Přeskočit</sys:String>

    <sys:String x:Key="L.Diag.Modded.Title">Varování: Upravený software</sys:String>
    <sys:String x:Key="L.Diag.Modded.Msg">Vybíráte upravenou verzi tohoto softwaru. Upravený software není oficiální a může obsahovat komunitní patče nebo modifikace.&#x0a;&#x0a;WinZ neodpovídá za případné problémy vzniklé použitím upraveného softwaru. Chcete pokračovat?</sys:String>

    <sys:String x:Key="L.Diag.Cancel.Title">Zrušit nastavení</sys:String>
    <sys:String x:Key="L.Diag.Cancel.Msg">Opravdu chcete zrušit nastavení? Tím se zastaví probílející operace a dojde k pokusu o vrácení změn.</sys:String>

    <sys:String x:Key="L.Diag.ModdedExp.Title">Experimentální funkce</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Msg">Povolení [upraveného softwaru] vám umožní instalovat komunitou upravené verze aplikací. Tyto verze mohou nabízet prémiové funkce nebo komunitní modifikace.&#x0a;&#x0a;Upravené položky budou v seznamu zvýrazněny [jemným modrým pozadím].&#x0a;&#x0a;**Varování:** Bezpečnost a stabilita nejsou zaručeny. Pokračujte na vlastní riziko.</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Confirm">Povolit</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Cancel">Zpět</sys:String>

