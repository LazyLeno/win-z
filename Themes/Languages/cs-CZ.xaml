    <sys:String x:Key="L.Rev.Confirm">Potvrdit a pokračovat</sys:String>

    <!-- Reinstall Dialog -->
    <sys:String x:Key="L.Rei.Title">Detekována přeinstalace</sys:String>
    <sys:String x:Key="L.Rei.Msg">Některé položky již ve vašem systému jsou. Odškrtněte ty, které si přejete přeskočit. Vybrané položky budou před čistou instalací odinstalovány.</sys:String>

