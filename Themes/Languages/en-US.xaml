    <!-- About Page -->
    <sys:String x:Key="L.About.Title">About WinZ</sys:String>
    <sys:String x:Key="L.About.Sources">Official Software Sources</sys:String>
    <sys:String x:Key="L.About.SourcesDesc">All standard software entries are fetched directly from official verified sources. WinZ utilizes Winget (Microsoft) and Scoop repositories to ensure you always receive authentic, untampered binaries.</sys:String>
    <sys:String x:Key="L.About.Trans">Transparency &amp; Local Processing</sys:String>
    <sys:String x:Key="L.About.TransDesc">WinZ operates entirely on your local machine. No telemetry, no cloud tracking, and no external data transmission. All database records and tweak scripts are executed with zero external dependencies.</sys:String>
    <sys:String x:Key="L.About.CreatedBy">CREATED BY </sys:String>

