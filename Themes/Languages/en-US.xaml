    <!-- Task Descriptions -->
    <sys:String x:Key="L.Desc.sw_librewolf">Privacy-focused Firefox fork with enhanced security defaults.</sys:String>
    <sys:String x:Key="L.Desc.sw_brave">Fast browser with built-in ad blocking and privacy features.</sys:String>
    <sys:String x:Key="L.Desc.sw_idm">High-speed download accelerator for all your files.</sys:String>
    <sys:String x:Key="L.Desc.sw_qbittorrent">Open-source alternative to µTorrent with advanced features.</sys:String>
    <sys:String x:Key="L.Desc.sw_protonvpn">Secure, no-logs VPN from the makers of ProtonMail.</sys:String>
    <sys:String x:Key="L.Desc.sw_simplewall">Configure Windows Filtering Platform (WFP) with ease.</sys:String>
    <sys:String x:Key="L.Desc.sw_malwarebytes">Advanced cybersecurity for home and business.</sys:String>
    <sys:String x:Key="L.Desc.sw_keepassxc">Cross-platform, community-driven password manager.</sys:String>
    <sys:String x:Key="L.Desc.sw_discord">Voice, video and text communication for communities.</sys:String>
    <sys:String x:Key="L.Desc.sw_obsidian">Powerful local Markdown-based knowledge base.</sys:String>
    <sys:String x:Key="L.Desc.sw_pear_desktop">Feature-rich YouTube Music desktop client.</sys:String>
    <sys:String x:Key="L.Desc.sw_vlc">Free cross-platform multimedia player for everything.</sys:String>
    <sys:String x:Key="L.Desc.sw_blender">Complete 3D creation suite (free and open source).</sys:String>
    <sys:String x:Key="L.Desc.sw_obs_studio">Professional software for recording and streaming.</sys:String>
    <sys:String x:Key="L.Desc.sw_steam">The ultimate platform for playing and discussing games.</sys:String>
    <sys:String x:Key="L.Desc.sw_epic">Epic Games store and official game launcher.</sys:String>
    <sys:String x:Key="L.Desc.sw_vscode">Powerful code editing, redefined for everyone.</sys:String>
    <sys:String x:Key="L.Desc.sw_notepadplus">Lightweight source code editor and replacement for Notepad.</sys:String>
    <sys:String x:Key="L.Desc.sw_sharex">Advanced screen capture and file sharing tool.</sys:String>
    <sys:String x:Key="L.Desc.sw_7zip">Archiver with high compression ratio and open source roots.</sys:String>
    <sys:String x:Key="L.Desc.sw_winrar">Powerful manager for ZIP, RAR and other archives.</sys:String>
    <sys:String x:Key="L.Desc.sw_onecommander">Modern dual-pane file manager with advanced features.</sys:String>
    <sys:String x:Key="L.Desc.sw_directory_opus">Professional-grade Windows Explorer replacement.</sys:String>
    <sys:String x:Key="L.Desc.tweak_verbose_login">Show detailed status messages during login/shutdown.</sys:String>
    <sys:String x:Key="L.Desc.tweak_disable_cortana">Disables Cortana search integration system-wide.</sys:String>
    <sys:String x:Key="L.Desc.rem_xbox_overlay">Removes the Xbox Game Bar overlay application.</sys:String>
    <sys:String x:Key="L.Desc.hw_disable_parking">Prevents Windows from putting CPU cores into sleep mode, reducing micro-stutters in games.</sys:String>
    <sys:String x:Key="L.Desc.hw_timer_res">Configures BCD to use a consistent platform tick, improving timing precision for high-performance applications.</sys:String>
    <sys:String x:Key="L.Desc.hw_enable_hags">Enables Hardware-Accelerated GPU Scheduling to reduce latency and improve frame rates on supported GPUs.</sys:String>
    <sys:String x:Key="L.Desc.hw_disable_mem_comp">Disables the Windows memory compression agent, reducing CPU overhead at the cost of higher RAM usage.</sys:String>
    <sys:String x:Key="L.Desc.hw_check_xmp">Checks the current RAM frequency and warns if it appears to be running at base speeds (XMP/EXPO off).</sys:String>
    <sys:String x:Key="L.Desc.hw_disable_fastboot">Disables Fast Startup to ensure a complete system refresh on every shutdown, preventing driver kernel bloat.</sys:String>
    <sys:String x:Key="L.Desc.set_allow_modded">Enables alternative, community-modded versions of certain software.</sys:String>
    <sys:String x:Key="L.Desc.set_prompt_restore">Asks to create a system restore point before starting any task.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_cleanup">Clears Windows Temp and package manager caches after a successful run.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_update">Automatically updates Winget and Scoop repositories on application launch.</sys:String>
    <sys:String x:Key="L.Desc.set_verify_checksums">Computes and validates SHA-256 hashes on all direct-download installers to detect tampering before execution.</sys:String>
    <sys:String x:Key="L.Desc.set_clm_mode">Runs all tweak scripts in PowerShell Constrained Language Mode. Hardens execution but may break scripts that use .NET types or COM objects.</sys:String>
    <sys:String x:Key="L.Desc.set_portable_mode">Keeps all data in RAM — no database files are written to disk. Ideal for USB use. Requires restart; all session data is lost on exit.</sys:String>

