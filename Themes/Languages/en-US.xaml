    <!-- CLM Warning Dialog -->
    <sys:String x:Key="L.Diag.Clm.Title">Execution Hardening Warning</sys:String>
    <sys:String x:Key="L.Diag.Clm.Msg">Enabling [Isolated PowerShell Execution] locks all tweak scripts into Constrained Language Mode (CLM).&#x0a;&#x0a;This prevents scripts from using .NET reflection, Add-Type, COM objects, and other advanced features. As a result:&#x0a;&#x0a;  • Some complex tweaks (e.g. [IDM modded install]) will fail to run.&#x0a;  • Scripts relying on external .NET APIs will be [blocked].&#x0a;&#x0a;Only enable this if you fully understand the trade-off. Do you want to continue?</sys:String>
    <sys:String x:Key="L.Diag.Clm.Confirm">Enable CLM</sys:String>
    <sys:String x:Key="L.Diag.Clm.Cancel">Go Back</sys:String>

    <!-- Portable Mode Dialogs -->
    <sys:String x:Key="L.Diag.Portable.Enable.Title">Enable Portable Mode</sys:String>
    <sys:String x:Key="L.Diag.Portable.Enable.Msg">**Portable Mode** keeps all WinZ data strictly in [memory] — no database files will be written to disk.&#x0a;&#x0a;This means:&#x0a;&#x0a;  • Your task selections and settings will [NOT persist] between sessions.&#x0a;  • Installation history will be [lost] when the app closes.&#x0a;  • The app [must be restarted] for this change to take effect.&#x0a;&#x0a;A sentinel file (**winz.portable**) will be placed next to the executable to activate this mode on next launch.&#x0a;&#x0a;Continue?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Title">Disable Portable Mode</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Msg">Disabling Portable Mode will restore persistent local storage. A database file will be created in your AppData folder on next launch.&#x0a;&#x0a;The app must be restarted for this change to take effect. Continue?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Confirm">Restart Now</sys:String>
    <sys:String x:Key="L.Diag.Portable.Cancel">Go Back</sys:String>

