    <sys:String x:Key="L.Rev.Confirm">Подтвердить и продолжить</sys:String>

    <!-- Reinstall Dialog -->
    <sys:String x:Key="L.Rei.Title">Обнаружена переустановка</sys:String>
    <sys:String x:Key="L.Rei.Msg">Некоторые элементы уже есть в системе. Снимите выделение с тех, которые не нужно переустанавливать. Выбранные элементы будут удалены перед чистой установкой.</sys:String>

