    <sys:String x:Key="L.Rev.Confirm">Bestätigen &amp; Weiter</sys:String>

    <!-- Reinstall Dialog -->
    <sys:String x:Key="L.Rei.Title">Neuinstallation erkannt</sys:String>
    <sys:String x:Key="L.Rei.Msg">Einige Elemente befinden sich bereits auf Ihrem System. Deaktivieren Sie alle, die Sie nicht neu installieren möchten. Ausgewählte Elemente werden vor der Neuinstallation deinstalliert.</sys:String>

