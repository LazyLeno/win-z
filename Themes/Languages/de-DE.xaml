    <!-- Dialogs -->
    <sys:String x:Key="L.Diag.Ready.Title">Bereit zum Anwenden</sys:String>
    <sys:String x:Key="L.Diag.Ready.Msg">Die gewählte Software und Tweaks werden nun angewendet.&#x0a;&#x0a;Speichern Sie Ihre Arbeit, da einige Vorgänge Systemkomponenten neu starten können.</sys:String>
    <sys:String x:Key="L.Diag.Ready.Confirm">Setup starten</sys:String>
    
    <sys:String x:Key="L.Diag.Safety.Title">Systemschutz</sys:String>
    <sys:String x:Key="L.Diag.Safety.Msg">Es wird empfohlen, einen Wiederherstellungspunkt zu erstellen. Dies bietet Sicherheit bei unerwartetem Verhalten.&#x0a;&#x0a;Möchten Sie jetzt einen Punkt erstellen? (Dauert ~30 Sek.)</sys:String>
    <sys:String x:Key="L.Diag.Safety.Confirm">Punkt erstellen</sys:String>
    <sys:String x:Key="L.Diag.Safety.Skip">Überspringen</sys:String>

    <sys:String x:Key="L.Diag.Modded.Title">Warnung: Modifizierte Software</sys:String>
    <sys:String x:Key="L.Diag.Modded.Msg">Sie wählen eine modifizierte Version. Diese ist nicht offiziell und kann Community-Patches enthalten.&#x0a;&#x0a;WinZ haftet nicht für Probleme. Möchten Sie fortfahren?</sys:String>

    <sys:String x:Key="L.Diag.Cancel.Title">Setup abbrechen</sys:String>
    <sys:String x:Key="L.Diag.Cancel.Msg">Sicher, dass Sie abbrechen wollen? Dies stoppt aktuelle Vorgänge.</sys:String>

    <sys:String x:Key="L.Diag.ModdedExp.Title">Experimentelle Funktionen</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Msg">Durch das Aktivieren von gemoddeter Software können Sie von der Community gepatchte Versionen von Anwendungen installieren. Diese Versionen können Premium-Funktionen oder Community-Modifikationen enthalten.&#x0a;&#x0a;Modifizierte Elemente werden in der Liste mit einem dezenten blauen Hintergrund angezeigt.&#x0a;&#x0a;Warnung: Sicherheit und Stabilität sind nicht garantiert. Die Verwendung erfolgt auf eigene Gefahr.</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Confirm">Aktivieren</sys:String>
    <sys:String x:Key="L.Diag.ModdedExp.Cancel">Zurück</sys:String>

    <!-- Review Dialog -->
    <sys:String x:Key="L.Rev.Title">Auswahl überprüfen</sys:String>
