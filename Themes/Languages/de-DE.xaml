    <!-- CLM Warning Dialog -->
    <sys:String x:Key="L.Diag.Clm.Title">Warnung zur Ausführungshärtung</sys:String>
    <sys:String x:Key="L.Diag.Clm.Msg">Die Aktivierung der isolierten PowerShell-Ausführung sperrt alle Tweak-Skripte in den Modus für eingeschränkte Sprache (CLM).&#x0a;&#x0a;Dies verhindert, dass Skripte .NET-Reflektion, COM-Objekte und andere fortgeschrittene Funktionen verwenden. Als Ergebnis:&#x0a;&#x0a;  • Einige komplexe Tweaks (z. B. modifizierte IDM-Installation) werden nicht ausgeführt.&#x0a;  • Skripte, die auf externe .NET-APIs angewiesen sind, werden blockiert.&#x0a;&#x0a;Aktivieren Sie dies nur, wenn Sie die Auswirkungen verstehen. Fortfahren?</sys:String>
    <sys:String x:Key="L.Diag.Clm.Confirm">CLM aktivieren</sys:String>
    <sys:String x:Key="L.Diag.Clm.Cancel">Zurück</sys:String>

    <!-- Portable Mode Dialogs -->
    <sys:String x:Key="L.Diag.Portable.Enable.Title">Portablen Modus aktivieren</sys:String>
    <sys:String x:Key="L.Diag.Portable.Enable.Msg">**Portabler Modus** hält alle WinZ-Daten strikt im [Arbeitsspeicher] – es werden keine Datenbankdateien auf die Festplatte geschrieben.&#x0a;&#x0a;Das bedeutet:&#x0a;&#x0a;  • Ihre Aufgabenauswahl und Einstellungen werden [NICHT gespeichert].&#x0a;  • Der Installationsverlauf geht beim Beenden [verloren].&#x0a;  • Die App [muss neu gestartet werden], damit diese Änderung wirksam wird.&#x0a;&#x0a;Eine Sentinel-Datei (**winz.portable**) wird neben der ausführbaren Datei platziert, um diesen Modus beim nächsten Start zu aktivieren.&#x0a;&#x0a;Fortfahren?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Title">Portablen Modus deaktivieren</sys:String>
    <sys:String x:Key="L.Diag.Portable.Disable.Msg">Das Deaktivieren des portablen Modus stellt den persistenten lokalen Speicher wieder her. Beim nächsten Start wird eine Datenbankdatei in Ihrem AppData-Ordner erstellt.&#x0a;&#x0a;Die App muss neu gestartet werden, damit diese Änderung wirksam wird. Fortfahren?</sys:String>
    <sys:String x:Key="L.Diag.Portable.Confirm">Jetzt neu starten</sys:String>
    <sys:String x:Key="L.Diag.Portable.Cancel">Zurück</sys:String>

    <!-- Error Messages -->
    <sys:String x:Key="L.Err.Cancelled">Benutzer hat abgebrochen</sys:String>
