    <!-- Task Descriptions -->
    <sys:String x:Key="L.Desc.sw_librewolf">Privatsphäre-fokussierter Firefox-Fork mit verbesserten Sicherheitseinstellungen.</sys:String>
    <sys:String x:Key="L.Desc.sw_brave">Schneller Browser mit integriertem Werbeblocker und Datenschutzfunktionen.</sys:String>
    <sys:String x:Key="L.Desc.sw_idm">Hochgeschwindigkeits-Download-Beschleuniger für alle Ihre Dateien.</sys:String>
    <sys:String x:Key="L.Desc.sw_qbittorrent">Open-Source-Alternative zu µTorrent mit erweiterten Funktionen.</sys:String>
    <sys:String x:Key="L.Desc.sw_protonvpn">Sicheres VPN ohne Protokollierung von den Machern von ProtonMail.</sys:String>
    <sys:String x:Key="L.Desc.sw_simplewall">Einfaches Tool zur Konfiguration der Windows Filtering Platform (WFP).</sys:String>
    <sys:String x:Key="L.Desc.sw_malwarebytes">Fortschrittliche Cybersicherheit für Privatpersonen und Unternehmen.</sys:String>
    <sys:String x:Key="L.Desc.sw_keepassxc">Plattformübergreifender, community-getriebener Passwortmanager.</sys:String>
    <sys:String x:Key="L.Desc.sw_discord">Sprach-, Video- und Textkommunikation für Communities.</sys:String>
    <sys:String x:Key="L.Desc.sw_obsidian">Leistungsstarke lokale Markdown-basierte Wissensdatenbank.</sys:String>
    <sys:String x:Key="L.Desc.sw_pear_desktop">Funktionsreicher YouTube Music Desktop-Client.</sys:String>
    <sys:String x:Key="L.Desc.sw_vlc">Kostenloser plattformübergreifender Multimedia-Player für alles.</sys:String>
    <sys:String x:Key="L.Desc.sw_blender">Komplette 3D-Erstellungssuite (kostenlos und Open Source).</sys:String>
    <sys:String x:Key="L.Desc.sw_obs_studio">Professionelle Software für Aufnahmen und Streaming.</sys:String>
    <sys:String x:Key="L.Desc.sw_steam">Die ultimative Plattform zum Spielen und Diskutieren von Spielen.</sys:String>
    <sys:String x:Key="L.Desc.sw_epic">Epic Games Store und offizieller Game-Launcher.</sys:String>
    <sys:String x:Key="L.Desc.sw_vscode">Leistungsstarke Code-Bearbeitung, neu definiert für alle.</sys:String>
    <sys:String x:Key="L.Desc.sw_notepadplus">Leichtgewichtiger Quelltext-Editor und Ersatz für Notepad.</sys:String>
    <sys:String x:Key="L.Desc.sw_sharex">Erweitertes Tool für Bildschirmaufnahmen und Filesharing.</sys:String>
    <sys:String x:Key="L.Desc.sw_7zip">Archivierungsprogramm mit hoher Kompressionsrate und Open-Source-Wurzeln.</sys:String>
    <sys:String x:Key="L.Desc.sw_winrar">Leistungsstarker Manager für ZIP-, RAR- und andere Archive.</sys:String>
    <sys:String x:Key="L.Desc.sw_onecommander">Moderner Zweifenster-Dateimanager mit erweiterten Funktionen.</sys:String>
    <sys:String x:Key="L.Desc.sw_directory_opus">Professioneller Windows Explorer Ersatz.</sys:String>
    <sys:String x:Key="L.Desc.tweak_verbose_login">Detaillierte Statusmeldungen während der Anmeldung/Abmeldung anzeigen.</sys:String>
    <sys:String x:Key="L.Desc.tweak_disable_cortana">Deaktiviert die Cortana-Suche systemweit.</sys:String>
    <sys:String x:Key="L.Desc.rem_xbox_overlay">Entfernt die Xbox Game Bar Overlay-Anwendung.</sys:String>
    <sys:String x:Key="L.Desc.set_allow_modded">Ermöglicht alternative, von der Community modifizierte Versionen bestimmter Software.</sys:String>
    <sys:String x:Key="L.Desc.set_prompt_restore">Fragt vor Beginn jeder Aufgabe nach der Erstellung eines Systemwiederherstellungspunkts.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_cleanup">Löscht den Windows-Temp-Ordner und Paketmanager-Caches nach einem erfolgreichen Durchlauf.</sys:String>
    <sys:String x:Key="L.Desc.set_auto_update">Aktualisiert Winget- und Scoop-Repositories automatisch beim Programmstart.</sys:String>
    <sys:String x:Key="L.Desc.set_verify_checksums">Berechnet und validiert SHA-256-Hashes für alle Direkt-Download-Installer, um Manipulationen vor der Ausführung zu erkennen.</sys:String>
    <sys:String x:Key="L.Desc.set_clm_mode">Führt alle Tweak-Skripte im PowerShell Constrained Language Mode aus. Erhöht die Sicherheit, kann aber Skripte unterbrechen, die .NET-Typen oder COM-Objekte verwenden.</sys:String>
    <sys:String x:Key="L.Desc.set_portable_mode">Hält alle Daten im RAM – es werden keine Datenbankdateien auf die Festplatte geschrieben. Ideal für die USB-Nutzung. Erfordert Neustart; alle Sitzungsdaten gehen beim Beenden verloren.</sys:String>

