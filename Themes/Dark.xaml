<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:WinZ.Converters">

    <!-- ── Converters ─────────────────────────────────────── -->
    <conv:StatusToBrushConverter          x:Key="StatusToBrush"/>
    <conv:StatusToIconConverter           x:Key="StatusToIcon"/>
    <conv:BoolToOpacityConverter          x:Key="BoolToOpacity"/>
    <conv:TaskTypeToLabelConverter        x:Key="TypeToLabel"/>
    <conv:TaskTypeToBrushConverter        x:Key="TypeToBrush"/>
    <conv:BoolToVisibilityConverter       x:Key="BoolToVis"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    <conv:IconUrlToVisibilityConverter    x:Key="IconUrlToVis"/>
    <conv:IconUrlToInverseVisibilityConverter x:Key="IconUrlToInvVis"/>

    <!-- ── Utilitarian Palette (Gray/Charcoal) ────────────── -->
    <SolidColorBrush x:Key="BgBrush"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#252525"/>
    <SolidColorBrush x:Key="Surface2Brush"  Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Border2Brush"   Color="#4A4A4A"/>
    <SolidColorBrush x:Key="PrimaryBrush"   Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="MutedBrush"     Color="#707070"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="#0078D4"/> <!-- Windows Blue -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="#004578"/>
    <SolidColorBrush x:Key="DangerBrush"    Color="#F04747"/>
    <SolidColorBrush x:Key="InfoBrush"      Color="#00A2AD"/>
    <SolidColorBrush x:Key="WarnBrush"      Color="#FFB900"/>

    <!-- ── Typography ────────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="12"/>
    </Style>

    <!-- ── Native-ish Scrollbar ───────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#252525"/>
        <Setter Property="Width"      Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#4A4A4A" Margin="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Native Style Button ────────────────────────────── -->
    <Style x:Key="NativeBtn" TargetType="Button">
        <Setter Property="Background"       Value="#333333"/>
        <Setter Property="Foreground"       Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Padding"          Value="12,4"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="BorderBrush"      Value="#444444"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#222222"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Primary Action Button ──────────────────────────── -->
    <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource NativeBtn}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ── Ghost / Secondary Button ──────────────────────── -->
    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource NativeBtn}">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ── Danger Button ─────────────────────────────────── -->
    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource NativeBtn}">
        <Setter Property="Foreground"  Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="#662222"/>
    </Style>

    <!-- ── Utilitarian Card Button ───────────────────────── -->
    <Style x:Key="CardBtn" TargetType="Button">
        <Setter Property="Background"      Value="#252525"/>
        <Setter Property="BorderBrush"     Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#2D2D2D"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Native Style Checkbox ─────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground"  Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box" Width="14" Height="14"
                                Background="#1A1A1A" BorderBrush="#555555" BorderThickness="1"
                                VerticalAlignment="Center" Margin="0,0,6,0">
                            <TextBlock x:Name="Chk" Text="✓" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Virtualization Hardening ───────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingStackPanel.CacheLengthUnit" Value="Item"/>
        <Setter Property="VirtualizingStackPanel.CacheLength" Value="10,10"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

    <Style TargetType="ItemsControl">
        <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
    </Style>

    <!-- ── Tooltip ──────────────────────────────────────── -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#444444"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

</ResourceDictionary>
