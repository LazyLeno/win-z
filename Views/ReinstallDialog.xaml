<Window x:Class="WinZ.Views.ReinstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reinstall Warning" Height="400" Width="480"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="#1A1A1A"
        BorderBrush="#3A3A3A" BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Reinstall Detected" FontSize="20" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,8"/>
        
        <TextBlock Grid.Row="1" Text="Some items are already on your system. Uncheck any you wish to skip re-installing. Selected items will be uninstalled before fresh installation." 
                   TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,20"/>

        <Border Grid.Row="2" Background="#252525" CornerRadius="4" Padding="12" Margin="0,0,0,20" BorderBrush="#333333" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ReinstallList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsReinstallSelected}" Content="{Binding Name}" Margin="0,6"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Go Back" Style="{StaticResource GhostBtn}" Click="Back_Click" Margin="0,0,12,0" Padding="16,6"/>
            <Button Content="Continue" Style="{StaticResource PrimaryBtn}" Click="Continue_Click" Width="110" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
