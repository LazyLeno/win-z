<Page x:Class="WinZ.Views.AdvancedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:WinZ.ViewModels"
      Background="#1A1A1A" Title="Advanced Setup"
      KeepAlive="False" Unloaded="Page_Unloaded">


    <Page.Resources>
        <!-- Reusable Group Template -->
        <DataTemplate x:Key="TaskGroupTemplate" DataType="{x:Type vm:TaskGroup}">
            <Border Margin="0,0,0,15" VerticalAlignment="Top">
                <StackPanel>
                    <!-- Sub-Category Header with Toggle -->
                    <Button Command="{Binding ToggleExpandCommand}" 
                            Background="#252525" Padding="10,6" Margin="0,0,0,5"
                            BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <TextBlock Text="{Binding GroupName}" FontWeight="Bold" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="Arrow" Text="▲" Foreground="#666666" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Task Items (Collapsible) -->
                    <ItemsControl ItemsSource="{Binding Tasks}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                        <Grid Grid.Column="1" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"
                                              Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}">
                                            <Image Source="{Binding IconImage}" 
                                                   Visibility="{Binding IconImage, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Icon}" 
                                                       Visibility="{Binding IconImage, Converter={StaticResource InvBoolToVis}}"
                                                       FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Foreground="White"/>
                                            <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#666666" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Category Tabs -->
            <RowDefinition Height="*"/>    <!-- Content Area -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Category Tabs -->
        <Border Grid.Row="0" Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <ListBox x:Name="TabList" 
                     ItemsSource="{Binding Tabs}"
                     SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Padding="20,12" Background="Transparent" BorderBrush="#0078D4" BorderThickness="0,0,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D2D2D"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="#AAAAAA"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Content Area (3-Column Masonry) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <Grid DataContext="{Binding SelectedTab}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/> <!-- Spacer -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/> <!-- Spacer -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ItemsControl Grid.Column="0" ItemsSource="{Binding Column1}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                <ItemsControl Grid.Column="2" ItemsSource="{Binding Column2}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                <ItemsControl Grid.Column="4" ItemsSource="{Binding Column3}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
            </Grid>
        </ScrollViewer>




        <!-- Footer -->
        <Border Grid.Row="2" Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <TextBlock x:Name="CountLabel" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Back" Style="{StaticResource GhostBtn}" Click="Back_Click" Margin="0,0,10,0" Width="80"/>
                    <Button x:Name="RunBtn" Content="Apply Selection" Style="{StaticResource PrimaryBtn}" Click="Run_Click" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
