<Page x:Class="WinZ.Views.AdvancedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:WinZ.ViewModels"
      xmlns:svc="clr-namespace:WinZ.Services"
      Background="{StaticResource BgBrush}" Title="Advanced Setup"
      KeepAlive="False" Unloaded="Page_Unloaded">


    <Page.Resources>
        <!-- Sort Direction to Angle Converter -->
        <vm:SortDirToAngleConverter x:Key="SortDirToAngle"/>
        <vm:SortActiveToVisConverter x:Key="SortActiveToVis"/>
        <vm:SortActiveToBrushConverter x:Key="SortActiveToBrush"/>

        <Style x:Key="HeaderBtnStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource SortActiveToBrush}">
                        <Binding Path="SortColumn"/>
                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#11FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SortArrowStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <!-- Reusable Group Template -->
        <DataTemplate x:Key="TaskGroupTemplate" DataType="{x:Type vm:TaskGroup}">
            <Border Margin="0,0,0,15" VerticalAlignment="Top">
                <StackPanel>
                    <!-- Sub-Category Header with Toggle -->
                    <Button Command="{Binding ToggleExpandCommand}" 
                            Background="{StaticResource SurfaceBrush}" Padding="10,6" Margin="0,0,0,5"
                            BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <TextBlock Text="{Binding GroupName, Converter={StaticResource Localize}, ConverterParameter=Cat}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="Arrow" Text="▲" Foreground="{StaticResource MutedBrush}" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Task Items (Collapsible) -->
                    <ItemsControl ItemsSource="{Binding Tasks}" Visibility="{Binding IsExpanded, Converter={StaticResource LogicToVis}}"
                                  RenderOptions.BitmapScalingMode="LowQuality">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1" Padding="10,6">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Use Community Enhanced Version" 
                                                      IsCheckable="True" 
                                                      IsChecked="{Binding IsModded}" 
                                                      Visibility="{Binding CanBeModded, Converter={StaticResource LogicToVis}}"/>
                                            <Separator Visibility="{Binding CanBeModded, Converter={StaticResource LogicToVis}}" Style="{StaticResource DropdownSeparator}"/>
                                            <MenuItem Header="Force Uninstall Before Install" IsCheckable="True" IsChecked="{Binding ShouldUninstallFirst}"/>
                                            <Separator Style="{StaticResource DropdownSeparator}"/>
                                            <MenuItem Header="Open Official Website" Click="OpenWebsite_Click">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource Icon.Link}" Fill="{StaticResource SecondaryBrush}" Stretch="Uniform" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                                  IsHitTestVisible="True"
                                                  Click="CheckBox_Click"/>

                                        <Image Grid.Column="1" Source="{Binding Id, Converter={StaticResource IconToImage}}"
                                               Width="24" Height="24" Margin="0,0,10,0" 
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               RenderOptions.BitmapScalingMode="LowQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <Grid Grid.Column="2" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource PrimaryBrush}" Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Name}" />
                                                
                                                <!-- Modded Badge -->
                                                <Border x:Name="ModTag" Visibility="Collapsed" Background="#FFB900" CornerRadius="2" Padding="4,0.5" Margin="6,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="MOD" FontSize="8" FontWeight="Bold" Foreground="#111111"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1" FontSize="9" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Opacity="0.8" Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Desc}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsModded}" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource ModdedCardBrush}"/>
                                        <Setter TargetName="ModTag" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsModded}" Value="True"/>
                                            <Condition Binding="{Binding IsMouseOver, ElementName=CardBorder}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CardBorder" Property="Background" Value="#353B45"/>
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu Bar -->
            <RowDefinition Height="Auto"/> <!-- Category Tabs -->
            <RowDefinition Height="Auto"/> <!-- Search Bar -->
            <RowDefinition Height="*"/>    <!-- Content Area -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{DynamicResource L.Menu.File}" Style="{StaticResource MenuBtn}" Click="FileMenu_Click"/>
                    <Button Content="{DynamicResource L.Menu.Settings}" Style="{StaticResource MenuBtn}" Click="Settings_Click"/>
                    <Button Content="{DynamicResource L.Menu.Help}" Style="{StaticResource MenuBtn}" Click="Info_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <!-- Portable Mode Indicator -->
                    <Image Visibility="{Binding IsPortableMode, Converter={StaticResource LogicToVis}}" 
                           Source="pack://application:,,,/Assets/status_portable.png" 
                           Width="14" Height="14" Opacity="0.8" Stretch="Uniform"
                           ToolTip="Portable Mode: No traces left on system" Margin="5,0"/>

                    <!-- Community Enhanced Indicator -->
                    <Image Visibility="{Binding IsCommunityEnhancedEnabled, Converter={StaticResource LogicToVis}}" 
                           Source="pack://application:,,,/Assets/status_community.png" 
                           Width="14" Height="14" Opacity="0.8" Stretch="Uniform"
                           ToolTip="Community Enhanced Apps: Modded versions enabled" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>        <!-- Category Tabs -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <!-- View 1: Main Category Selection -->
                <ListBox x:Name="CategoryList"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Visibility="{Binding IsCategorySelected, Converter={StaticResource LogicToVis}, ConverterParameter=Inverse}"
                         Background="Transparent" BorderThickness="0" Padding="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Padding="16,8" Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <Image x:Name="CatIcon" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"/>
                                                <TextBlock Text="{Binding Converter={StaticResource Localize}, ConverterParameter=Tab}" Foreground="{StaticResource SecondaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding}" Value="Software">
                                                <Setter TargetName="CatIcon" Property="Source" Value="pack://application:,,,/Assets/tab_software.png"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Windows">
                                                <Setter TargetName="CatIcon" Property="Source" Value="pack://application:,,,/Assets/tab_windows.png"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Hardware">
                                                <Setter TargetName="CatIcon" Property="Source" Value="pack://application:,,,/Assets/tab_hardware.png"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- View 2: Drill-down (Selected Category + Sub-Categories) -->
                <Grid Visibility="{Binding IsCategorySelected, Converter={StaticResource LogicToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Selected Category -->
                        <ColumnDefinition Width="*"/>    <!-- Sub-Categories -->
                        <ColumnDefinition Width="Auto"/> <!-- Back Button -->
                    </Grid.ColumnDefinitions>

                    <!-- Selected Category (Pushed to left) -->
                    <Border Grid.Column="0" Background="{StaticResource BgBrush}" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="ActiveCatIcon" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedCategory}" Value="Software"><Setter Property="Source" Value="pack://application:,,,/Assets/tab_software.png"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedCategory}" Value="Windows"><Setter Property="Source" Value="pack://application:,,,/Assets/tab_windows.png"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedCategory}" Value="Hardware"><Setter Property="Source" Value="pack://application:,,,/Assets/tab_hardware.png"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="{Binding SelectedCategory, Converter={StaticResource Localize}, ConverterParameter=Tab}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sub-Categories (Sections) -->
                    <ListBox Grid.Column="1" 
                             ItemsSource="{Binding Sections}" 
                             SelectedItem="{Binding SelectedSection}"
                             Background="Transparent" BorderThickness="0" Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Padding="16,8" Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Cursor="Hand">
                                                <TextBlock Text="{Binding Converter={StaticResource Localize}, ConverterParameter=Sec}" Foreground="{StaticResource SecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Back Button (Right) -->
                    <Button Grid.Column="2" Command="{Binding BackCommand}" Background="Transparent" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}" Padding="12,0" Width="44">
                        <Path Data="M19,11H7.83l5.59-5.59L12,4l-8,8l8,8l1.41-1.41L7.83,13H19V11z" Fill="{StaticResource SecondaryBrush}" Stretch="Uniform" Width="16" Height="16"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#CC3333"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="2" Background="#212121" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1" Padding="20,10"
                Visibility="{Binding IsCategorySelected, Converter={StaticResource LogicToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" FontSize="12" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Grid Grid.Column="1">
                    <TextBlock Text="{DynamicResource L.Adv.Search}"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" FontStyle="Italic"
                               VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"
                             VerticalAlignment="Center" x:Name="SearchBox" Padding="0,2"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             HOMEPAGE  (no category selected)
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3"
              Visibility="{Binding DataContext.IsCategorySelected, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource LogicToVis}, ConverterParameter=Inverse}"
              Background="{StaticResource BgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- hw strip -->
                <RowDefinition Height="*"/>     <!-- tweaks list -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1"
                    DataContext="{x:Static svc:HardwareService.Instance}">
                <StackPanel>
                    <!-- Row 1: Hardware Gauges (Evenly Spaced) -->
                    <Grid Margin="20,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <!-- CPU -->
                            <ColumnDefinition Width="Auto"/> <!-- Div -->
                            <ColumnDefinition Width="*"/> <!-- RAM -->
                            <ColumnDefinition Width="Auto"/> <!-- Div -->
                            <ColumnDefinition Width="*"/> <!-- GPU -->
                        </Grid.ColumnDefinitions>

                        <!-- CPU -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="60" Height="34">
                                <Path Stroke="#282828" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <Path x:Name="CpuArcPath" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Stroke><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0055CC" Offset="0"/><GradientStop Color="#00A8FF" Offset="1"/></LinearGradientBrush></Path.Stroke>
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F0}%'}" FontSize="10" FontWeight="SemiBold" Foreground="#C0C0C0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </Grid>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CpuName}" FontSize="11" FontWeight="SemiBold" Foreground="#D0D0D0" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                <TextBlock Text="{Binding CpuSpecs}" FontSize="9" Foreground="#484848" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#2A2A2A" Margin="0,4"/>

                        <!-- RAM -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="60" Height="34">
                                <Path Stroke="#282828" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <Path x:Name="RamArcPath" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Stroke><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#00C853" Offset="0"/><GradientStop Color="#B2FF59" Offset="1"/></LinearGradientBrush></Path.Stroke>
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <TextBlock Text="{Binding RamUsage, StringFormat='{}{0:F0}%'}" FontSize="10" FontWeight="SemiBold" Foreground="#C0C0C0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </Grid>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RamLoad}" FontSize="11" FontWeight="SemiBold" Foreground="#D0D0D0" MaxWidth="150"/>
                                <TextBlock Text="{Binding RamSpecs}" FontSize="9" Foreground="#484848" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Grid.Column="3" Width="1" Fill="#2A2A2A" Margin="0,4"/>

                        <!-- GPU -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="60" Height="34">
                                <Path Stroke="#282828" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <Path x:Name="GpuArcPath" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Stroke><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#7B1FA2" Offset="0"/><GradientStop Color="#CE93D8" Offset="1"/></LinearGradientBrush></Path.Stroke>
                                    <Path.Data><PathGeometry><PathFigure StartPoint="4,30"><ArcSegment Point="56,30" Size="26,26" SweepDirection="Clockwise" IsLargeArc="True"/></PathFigure></PathGeometry></Path.Data>
                                </Path>
                                <TextBlock Text="{Binding GpuUsage, StringFormat='{}{0:F0}%'}" FontSize="10" FontWeight="SemiBold" Foreground="#C0C0C0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </Grid>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding GpuName}" FontSize="11" FontWeight="SemiBold" Foreground="#D0D0D0" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                <TextBlock Text="{Binding GpuSpecs}" FontSize="9" Foreground="#484848" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: OS Info Bar (Centered) -->
                    <Border Background="#181818" Padding="20,4" BorderBrush="#252525" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Assets/status_windows.png" Width="12" Height="12" Opacity="0.7" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding OsSpecs}" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="8" Fill="#252525" Margin="12,0"/>
                            <TextBlock Text="{Binding OsStatus}" FontSize="10" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActivated}" Value="True">
                                                <Setter Property="Foreground" Value="#00C853"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Selected Tweaks Summary ─────────────────────────────── -->
            <Grid Grid.Row="1">
                <!-- Empty state -->
                <TextBlock Text=""
                           Foreground="#333" FontSize="11" FontStyle="Italic"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding SelectedCount, Converter={StaticResource LogicToVis}, ConverterParameter=Inverse}"/>

                <!-- Grouped tweaks list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedCount, Converter={StaticResource LogicToVis}}">
                    <ItemsControl ItemsSource="{Binding SelectedTasksView}"
                                  VirtualizingPanel.IsVirtualizing="False">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#1C1C1C" Padding="16,5" BorderBrush="#252525" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name, Converter={StaticResource Localize}, ConverterParameter=Tab}"
                                                           FontSize="9" FontWeight="Bold" Foreground="#484848"/>
                                                <TextBlock Text=" · " FontSize="9" Foreground="#333"/>
                                                <TextBlock Text="{Binding ItemCount}" FontSize="9" Foreground="#333"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,6" BorderBrush="#222" BorderThickness="0,0,0,1"
                                        Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>  <!-- checkbox -->
                                            <ColumnDefinition Width="18"/>    <!-- icon -->
                                            <ColumnDefinition Width="*"/>     <!-- name + desc -->
                                            <ColumnDefinition Width="Auto"/>  <!-- section badge -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0" Click="CheckBox_Click"/>

                                        <Image Grid.Column="1"
                                               Source="{Binding Id, Converter={StaticResource IconToImage}}"
                                               Width="14" Height="14" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="LowQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,12,0">
                                            <TextBlock Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Name}"
                                                       FontSize="11" Foreground="#C8C8C8" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Desc}"
                                                       FontSize="9" Foreground="#484848" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Section, Converter={StaticResource Localize}, ConverterParameter=Sec}"
                                                   FontSize="8" Foreground="#333" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>


        <!-- Content Grid (Wrapped in a Visibility toggle) -->
        <Grid Grid.Row="3" Visibility="{Binding IsCategorySelected, Converter={StaticResource LogicToVis}}">
            <!-- Content Area: Standard Tweaks -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="Overview">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid DataContext="{Binding SelectedTab}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/> <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/> <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
    
                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Column1}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Column2}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                    <ItemsControl Grid.Column="4" ItemsSource="{Binding Column3}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                </Grid>
            </ScrollViewer>
    
            <!-- Content Area: Software Overview (Installed Apps) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <ScrollViewer.Visibility>
                    <Binding Path="SelectedSection" Converter="{StaticResource ValueToVis}" ConverterParameter="Overview"/>
                </ScrollViewer.Visibility>
                <StackPanel>
                    <!-- Header Row -->
                    <Border Background="#1F1F1F" CornerRadius="4,4,0,0" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1,1,1,0">
                    <Grid Height="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>     <!-- Icon padding -->
                            <ColumnDefinition Width="2*"/>    <!-- Name -->
                            <ColumnDefinition Width="1"/>     <!-- Separator -->
                            <ColumnDefinition Width="1.5*"/>  <!-- Author -->
                            <ColumnDefinition Width="1"/>     <!-- Separator -->
                            <ColumnDefinition Width="100"/>    <!-- Size -->
                            <ColumnDefinition Width="1"/>     <!-- Separator -->
                            <ColumnDefinition Width="120"/>    <!-- Version -->
                            <ColumnDefinition Width="100"/>    <!-- Uninstall -->
                        </Grid.ColumnDefinitions>

                        <!-- Name Header -->
                        <Button Grid.Column="1" Command="{Binding SortCommand}" CommandParameter="Name" Style="{StaticResource HeaderBtnStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="APP NAME" Style="{StaticResource HeaderTextStyle}"/>
                                <TextBlock x:Name="NameArrow" Text="▲" Style="{StaticResource SortArrowStyle}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource SortActiveToVis}">
                                            <Binding Path="SortColumn"/><Binding Source="Name"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding SortDirection, Converter={StaticResource SortDirToAngle}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="2" Fill="{StaticResource Surface2Brush}" Margin="0,8"/>

                        <!-- Author Header -->
                        <Button Grid.Column="3" Command="{Binding SortCommand}" CommandParameter="Publisher" Style="{StaticResource HeaderBtnStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="AUTHOR" Style="{StaticResource HeaderTextStyle}"/>
                                <TextBlock Text="▲" Style="{StaticResource SortArrowStyle}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource SortActiveToVis}">
                                            <Binding Path="SortColumn"/><Binding Source="Publisher"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding SortDirection, Converter={StaticResource SortDirToAngle}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="4" Fill="{StaticResource Surface2Brush}" Margin="0,8"/>

                        <!-- Size Header -->
                        <Button Grid.Column="5" Command="{Binding SortCommand}" CommandParameter="Size" Style="{StaticResource HeaderBtnStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="SIZE" Style="{StaticResource HeaderTextStyle}"/>
                                <TextBlock Text="▲" Style="{StaticResource SortArrowStyle}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource SortActiveToVis}">
                                            <Binding Path="SortColumn"/><Binding Source="Size"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding SortDirection, Converter={StaticResource SortDirToAngle}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="6" Fill="{StaticResource Surface2Brush}" Margin="0,8"/>

                        <!-- Version Header -->
                        <Button Grid.Column="7" Command="{Binding SortCommand}" CommandParameter="Version" Style="{StaticResource HeaderBtnStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="VERSION" Style="{StaticResource HeaderTextStyle}"/>
                                <TextBlock Text="▲" Style="{StaticResource SortArrowStyle}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource SortActiveToVis}">
                                            <Binding Path="SortColumn"/><Binding Source="Version"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding SortDirection, Converter={StaticResource SortDirToAngle}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding InstalledAppsView}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1,0,1,1" Padding="0,6"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource WinZContextMenu}">
                                        <MenuItem Header="Open Installation Directory" 
                                                  Command="{Binding PlacementTarget.Tag.OpenInstallDirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Path Data="M20,6h-8l-2-2H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z" Fill="{StaticResource SecondaryBrush}" Stretch="Uniform" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Grid>
                                        <Image Source="{Binding Icon}" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <Border Width="20" Height="20" Background="#2A2A2A" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="?" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource PrimaryBrush}" 
                                               FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="10,0" TextTrimming="CharacterEllipsis"/>

                                    <Rectangle Grid.Column="2" Fill="{StaticResource Surface2Brush}" Margin="0,2" Opacity="0.3"/>
                                    
                                    <TextBlock Grid.Column="3" Text="{Binding Publisher}" Foreground="{StaticResource MutedBrush}" 
                                               FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                    <Rectangle Grid.Column="4" Fill="{StaticResource Surface2Brush}" Margin="0,2" Opacity="0.3"/>

                                    <TextBlock Grid.Column="5" Text="{Binding Size}" Foreground="{StaticResource SecondaryBrush}" 
                                               FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <Rectangle Grid.Column="6" Fill="{StaticResource Surface2Brush}" Margin="0,2" Opacity="0.3"/>

                                    <TextBlock Grid.Column="7" Text="{Binding Version}" Foreground="{StaticResource MutedBrush}" 
                                               FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <Button Grid.Column="8" Content="Uninstall" 
                                            Command="{Binding DataContext.SmartUninstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerBtn}" Padding="10,2" FontSize="10" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding SelectedCount}" Foreground="{StaticResource SecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text=" " VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L.Adv.ItemsSelected}" Foreground="{StaticResource SecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button IsEnabled="{Binding SelectedCount, Converter={StaticResource CountToBool}}" Content="{DynamicResource L.Adv.RunBtn}" Style="{StaticResource PrimaryBtn}" Click="Run_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
