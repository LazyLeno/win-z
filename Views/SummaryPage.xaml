<Page x:Class="WinZ.Views.SummaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A" Title="Summary">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">
            <StackPanel Margin="20,15">
                <TextBlock x:Name="HeadingLabel" Text="Setup Complete" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="HeadingSubLabel" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Stats row (Utilitarian boxes) -->
        <Border Grid.Row="1" Background="#212121" Padding="20,10" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Succeeded: " FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SucceededCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#4ADE80" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Failed: " FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FailedCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#F04747" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Skipped: " FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SkippedCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#AAAAAA" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Result list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultList" Margin="20,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                    <TextBlock Text="{Binding ErrorDetail}" FontSize="9" Foreground="#F04747" Margin="0,1,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding ErrorDetail, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12">
                <Button Content="View Logs" Style="{StaticResource GhostBtn}" Click="ViewLog_Click" Margin="0,0,10,0" Width="90"/>
                <Button Content="Finish" Style="{StaticResource PrimaryBtn}" Click="Close_Click" Width="90"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
