<Page x:Class="WinZ.Views.SummaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A" Title="Summary"
      KeepAlive="False" Unloaded="Page_Unloaded">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">
            <StackPanel Margin="20,15">
                <TextBlock Text="{DynamicResource L.Sum.SuccessHeader}" FontSize="18" FontWeight="Bold" Foreground="White"
                           Visibility="{Binding HasFailures, Converter={StaticResource LogicToVis}, ConverterParameter=Inverse}"/>
                <TextBlock Text="{DynamicResource L.Sum.SuccessSub}" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"
                           Visibility="{Binding HasFailures, Converter={StaticResource LogicToVis}, ConverterParameter=Inverse}"/>
                
                <TextBlock Text="{DynamicResource L.Sum.ErrorHeader}" FontSize="18" FontWeight="Bold" Foreground="#F87171"
                           Visibility="{Binding HasFailures, Converter={StaticResource LogicToVis}}"/>
                <StackPanel Orientation="Horizontal" Visibility="{Binding HasFailures, Converter={StaticResource LogicToVis}}">
                    <TextBlock Text="{Binding Failed}" FontSize="11" Foreground="#F87171" FontWeight="Bold"/>
                    <TextBlock Text=" "/>
                    <TextBlock Text="{DynamicResource L.Sum.ErrorSub}" FontSize="11" Foreground="#AAAAAA"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Stats row (Utilitarian boxes) -->
        <Border Grid.Row="1" Background="#212121" Padding="20,10" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource L.Sum.Succeeded}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Succeeded}" FontSize="14" FontWeight="Bold" Foreground="#4ADE80" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource L.Sum.Failed}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Failed}" FontSize="14" FontWeight="Bold" Foreground="#F04747" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource L.Sum.Skipped}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Skipped}" FontSize="14" FontWeight="Bold" Foreground="#AAAAAA" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Result list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultList" Margin="20,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#212121"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                            <Setter Property="Background" Value="#1B2B1B"/>
                                            <Setter Property="BorderBrush" Value="#2A3D2A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding TaskId, Converter={StaticResource Localize}, ConverterParameter=Name}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                    <TextBlock Text="{Binding ErrorDetail, Converter={StaticResource Localize}}" FontSize="9" Foreground="#F04747" Margin="0,1,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding ErrorDetail, Converter={StaticResource LogicToVis}}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding StatusLabel, Converter={StaticResource Localize}}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12">
                <Button Content="{DynamicResource L.Sum.ViewLogs}" Style="{StaticResource GhostBtn}" Click="ViewLog_Click" Margin="0,0,10,0" Width="90"/>
                <Button Content="{DynamicResource L.Sum.Finish}" Style="{StaticResource PrimaryBtn}" Click="Close_Click" Width="90"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
