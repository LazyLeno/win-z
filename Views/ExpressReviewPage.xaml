<Page x:Class="WinZ.Views.ExpressReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinZ.Converters"
      Background="#1A1A1A" Title="Express Review">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">
            <Grid Margin="20,15">
                <StackPanel>
                    <TextBlock Text="Review Express Setup" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="The following components will be installed and configured" Foreground="#AAAAAA" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="Back" Style="{StaticResource GhostBtn}" Click="Back_Click"/>
            </Grid>
        </Border>

        <!-- Task list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="GroupsPanel" Margin="20,10"/>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <TextBlock x:Name="CountLabel" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource GhostBtn}" Click="Back_Click" Margin="0,0,10,0" Width="80"/>
                    <Button x:Name="RunBtn" Content="Start Setup" Style="{StaticResource PrimaryBtn}" Click="Run_Click" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
