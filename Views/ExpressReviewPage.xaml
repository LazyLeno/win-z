<Page x:Class="WinZ.Views.ExpressReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinZ.Converters"
      xmlns:models="clr-namespace:WinZ.Models"
      xmlns:vm="clr-namespace:WinZ.ViewModels"
      Background="#1A1A1A" Title="Express Review"

      KeepAlive="False" Unloaded="Page_Unloaded">

    <Page.Resources>
        <DataTemplate x:Key="TaskTemplate" DataType="{x:Type models:SetupTask}">
            <Border Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                              VerticalAlignment="Center" Margin="0,0,10,0"
                              Checked="OnSelectionChanged" Unchecked="OnSelectionChanged"/>

                    <Grid Grid.Column="1" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"
                          Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}">
                        <Image Source="{Binding IconImage}" 
                               Visibility="{Binding IconImage, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding Icon}" 
                                   Visibility="{Binding IconImage, Converter={StaticResource InvBoolToVis}}"
                                   FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Foreground="White"/>
                        <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#666666" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TaskGroupTemplate" DataType="{x:Type vm:TaskGroup}">
            <Border Margin="0,0,0,15" VerticalAlignment="Top">
                <StackPanel>
                    <Border Background="#252525" Padding="10,6" Margin="0,0,0,5">
                        <TextBlock Text="{Binding GroupName}" FontWeight="Bold" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Tasks}" ItemTemplate="{StaticResource TaskTemplate}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">
            <Grid Margin="20,15">
                <StackPanel>
                    <TextBlock Text="Review Express Setup" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="The following components will be installed and configured" Foreground="#AAAAAA" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="Back" Style="{StaticResource GhostBtn}" Click="Back_Click"/>
            </Grid>
        </Border>

        <!-- Task list (3-Column Masonry) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ItemsControl Grid.Column="0" ItemsSource="{Binding Col1}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                <ItemsControl Grid.Column="2" ItemsSource="{Binding Col2}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
                <ItemsControl Grid.Column="4" ItemsSource="{Binding Col3}" ItemTemplate="{StaticResource TaskGroupTemplate}"/>
            </Grid>
        </ScrollViewer>



        <!-- Footer -->
        <Border Grid.Row="2" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <TextBlock x:Name="CountLabel" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource GhostBtn}" Click="Back_Click" Margin="0,0,10,0" Width="80"/>
                    <Button x:Name="RunBtn" Content="Start Setup" Style="{StaticResource PrimaryBtn}" Click="Run_Click" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

