<Page x:Class="WinZ.Views.RunningPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A" Title="Running"
      KeepAlive="False" Unloaded="Page_Unloaded">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">
            <StackPanel Margin="20,15">
                <TextBlock x:Name="CurrentTaskLabel" Text="Starting Setup..." FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="SubLabel" Text="Initializing installation engine" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Progress bar (Utilitarian) -->
        <Border Grid.Row="1" Background="#212121" Padding="20,10" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="ProgressLabel" Text="0 / 0" FontSize="10" Foreground="#888888" HorizontalAlignment="Right"/>
                </Grid>
                <Border Background="#333333" Height="4">
                    <Border x:Name="ProgressFill" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left" Width="0"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Task list (Flat list) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" x:Name="TaskScroller">
            <ItemsControl x:Name="TaskList" Margin="20,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#212121" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                           FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                                    <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#555555"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Log panel (Dense, console-like) -->
        <Border Grid.Row="3" Background="#141414" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0">
            <StackPanel>
                <Button x:Name="LogToggleBtn" Click="LogToggle_Click" Background="Transparent" BorderThickness="0" Padding="20,8" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="LogArrow" Text="▶" FontSize="8" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#666666"/>
                        <TextBlock Text="Detailed Log" FontSize="10" Foreground="#666666"/>
                    </StackPanel>
                </Button>
                <Border x:Name="LogPanel" Height="0">
                    <ScrollViewer x:Name="LogScroller" MaxHeight="150" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogBox" IsReadOnly="True" Background="Black" Foreground="#00FF00" FontFamily="Consolas" FontSize="10" BorderThickness="0" Padding="20,5" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
