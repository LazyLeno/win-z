<Page x:Class="WinZ.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:WinZ.ViewModels"
      Background="{StaticResource BgBrush}" Title="Settings"
      KeepAlive="False" Unloaded="Page_Unloaded">

    <Page.Resources>
        <!-- Modern Setting Row Template -->
        <DataTemplate x:Key="SettingItemTemplate">
            <Border Background="Transparent" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding Id, Converter={StaticResource Localize}, ConverterParameter=Desc}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <!-- Toggle Style Checkbox -->
                    <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                              VerticalAlignment="Center" Click="CheckBox_Click">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="Track" Width="34" Height="18" CornerRadius="9" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
                                                <Ellipse x:Name="Thumb" Width="12" Height="12" Fill="{StaticResource SecondaryBrush}" HorizontalAlignment="Left" Margin="2,0">
                                                    <Ellipse.RenderTransform>
                                                        <TranslateTransform X="0"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="16" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SettingGroupTemplate" DataType="{x:Type vm:TaskGroup}">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{Binding GroupName, Converter={StaticResource Localize}, ConverterParameter=Cat}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" FontSize="11" Margin="12,0,0,6" Opacity="0.8"/>
                <ItemsControl ItemsSource="{Binding Tasks}" ItemTemplate="{StaticResource SettingItemTemplate}"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/> <!-- Category Tabs -->
            <RowDefinition Height="*"/>    <!-- Content Area -->
        </Grid.RowDefinitions>

        <!-- Floating Back Button (1:1 Ratio) -->
        <Button Grid.Row="0" Click="Back_Click"
                Width="32" Height="32"
                HorizontalAlignment="Right" VerticalAlignment="Center" Panel.ZIndex="99"
                Style="{StaticResource GhostBtn}" Padding="8" Margin="0,6,6,6">
            <Path Fill="{StaticResource SecondaryBrush}" Stretch="Uniform"
                  Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
        </Button>

        <!-- Category Tabs -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1">
            <ListBox x:Name="TabList"
                     ItemsSource="{Binding Tabs}"
                     SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <Border x:Name="Bd" Padding="16,10" Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="Accent" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                            <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name, Converter={StaticResource Localize}, ConverterParameter=Tab}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Stretch" Margin="20,15">
                
                <!-- Special Language Section for General Tab -->
                <StackPanel Visibility="{Binding SelectedTab.Name, Converter={StaticResource LogicToVis}, ConverterParameter=General}">
                    <TextBlock Text="{DynamicResource L.Set.Language}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" FontSize="11" Margin="12,0,0,6" Opacity="0.8"/>
                    <Border Background="Transparent" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="0,0,0,1" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource L.Set.Language}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L.Set.LanguageDesc}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <ComboBox Grid.Column="1" Width="140" Height="26" VerticalAlignment="Center"
                                      Style="{StaticResource NativeComboBox}"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      DisplayMemberPath="Value"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Regular Settings Items -->
                <ItemsControl ItemsSource="{Binding SelectedTab.SubGroups}" 
                              ItemTemplate="{StaticResource SettingGroupTemplate}"
                              RenderOptions.BitmapScalingMode="LowQuality"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
