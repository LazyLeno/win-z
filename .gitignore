## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Visual Studio Code
.vscode/

# Entity Framework Core
*.design.time.cache.json

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Image Master
*.cache
*.resource
*.webinfo

# CoreCLR dumps
core.[0-9]*

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCop.Cache
StyleCop.Settings

# Files for MS Build
*.FileListAbsolute.txt

# Backup & checkpoint files
*~
*.bak
*.cache
*.ilk
*.log
*.pdb
*.sbr
*.tmp
*.tmp_proj
*.vspscc
*.vssscc
enlistment.config
hintpath.config
*.loadtest
*.setettings

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Azure Build Output
csx/
*.build.csdef

# Azure Search Indexer
*.worker.cache

# Microsoft Azure Emulator
ecf/
rcf/

# Azure Cloud Service projects
Intermediate/
Model/

# Others
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.dot

# Including light-weight version control systems
.hg/
.svn/

# Local Config
*.local.json
